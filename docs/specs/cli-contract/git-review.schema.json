{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas://cli-contract/git-review.schema.json",
  "title": "brain git review <runId> — --json success output",
  "description": "Read-only inspection of a review-pending run: the diff against its base commit plus the run manifest (state, risk tier, validation, agent commit). Non-mutating — no branch/worktree/ref/ledger/audit write. Exit 0 on a reviewable run; exit 1 when the run does not exist or is not in a reviewable state.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["command", "runId", "state", "risk", "manifest"],
  "properties": {
    "command": { "const": "git review" },
    "runId": { "type": "string", "minLength": 1, "description": "ULID run id." },
    "state": {
      "description": "The run's workflow state (must be reviewable).",
      "enum": ["review-pending"]
    },
    "risk": { "enum": ["tier-1", "tier-2", "tier-3"], "description": "Proposed risk tier of the run." },
    "diff": { "type": "string", "description": "Unified diff of the agent commit against its base commit." },
    "summary": {
      "type": "object",
      "unevaluatedProperties": false,
      "description": "Aggregate change statistics for the diff.",
      "properties": {
        "filesChanged": { "type": "integer", "minimum": 0 },
        "insertions": { "type": "integer", "minimum": 0 },
        "deletions": { "type": "integer", "minimum": 0 }
      }
    },
    "manifest": {
      "type": "object",
      "unevaluatedProperties": false,
      "required": ["branch", "baseCommit", "agentCommit", "validation"],
      "description": "The run manifest — the immutable descriptor of what is under review.",
      "properties": {
        "branch": { "type": "string", "minLength": 1, "description": "refs/agent/<runId>." },
        "baseCommit": { "type": "string", "minLength": 1, "description": "40-char hex base commit the agent branch is based on." },
        "agentCommit": { "type": "string", "minLength": 1, "description": "40-char hex agent commit under review." },
        "validation": { "enum": ["pending", "passed", "failed"], "description": "Validation status of the run's patch." }
      }
    }
  },
  "examples": [
    {
      "command": "git review",
      "runId": "01J9Z8Q0000000000000000000",
      "state": "review-pending",
      "risk": "tier-3",
      "diff": "diff --git a/notes/project-meridian.md b/notes/project-meridian.md\n@@ -1 +1,2 @@\n line\n+added",
      "summary": { "filesChanged": 1, "insertions": 1, "deletions": 0 },
      "manifest": {
        "branch": "refs/agent/01J9Z8Q0000000000000000000",
        "baseCommit": "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0",
        "agentCommit": "b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1",
        "validation": "passed"
      }
    }
  ],
  "x-atlas-contract": {
    "command": "git review",
    "phase": 4,
    "privilege": "shared",
    "idempotency": "none",
    "executionClass": "read",
    "summary": "Read-only diff + manifest of a review-pending run; no mutation.",
    "args": [
      { "arg": "<runId>", "type": "string", "required": true, "description": "The run id to review." }
    ],
    "flags": [],
    "commonFlags": ["--json", "--quiet", "--verbose", "--plain", "--no-color", "--config <path>", "--vault <path>"],
    "sideEffects": [],
    "prohibitedEffects": ["no branch/worktree/ref mutation", "no ledger or audit-ref write"],
    "locks": [{ "scope": "shared", "mode": "shared" }],
    "exitCodes": [0, 1, 2, 4, 5],
    "errorCodes": [
      { "code": "usage", "exit": 5, "when": "unknown flag/argument or missing <runId>" },
      { "code": "run-not-found", "exit": 1, "when": "<runId> does not exist" },
      { "code": "not-reviewable", "exit": 1, "when": "the run is not in a reviewable (review-pending) state" },
      { "code": "vault-error", "exit": 2, "when": "the vault repo is missing or unreadable" },
      { "code": "internal", "exit": 4, "when": "unexpected internal failure" }
    ],
    "errorEnvelopeRef": "docs/specs/cli-contract/error-envelope.schema.json"
  }
}
