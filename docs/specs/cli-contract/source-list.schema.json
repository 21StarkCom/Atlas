{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas://cli-contract/source-list.schema.json",
  "title": "brain source list — --json success output",
  "description": "Paginated read-only list of registered sources from the v2 operational `source` registry (0015_source_registry). Best-effort under concurrency (plan §2.5). Tier-0 read; no mutation.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["command", "sources", "pagination"],
  "properties": {
    "command": { "const": "source list" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "unevaluatedProperties": false,
        "required": ["id", "kind", "locator", "addedAt"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["file", "url"] },
          "locator": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "addedAt": { "type": "string", "description": "RFC-3339 time the source was added." },
          "lastIngestedAt": { "type": "string", "description": "RFC-3339 time `ingest` last folded this source (present only once ingested)." }
        }
      }
    },
    "pagination": {
      "type": "object",
      "unevaluatedProperties": false,
      "required": ["limit", "offset", "total", "hasMore"],
      "properties": {
        "limit": { "type": "integer", "minimum": 1, "maximum": 500 },
        "offset": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0, "description": "Live (non-snapshot) total row count across all pages; best-effort under concurrent inserts/deletes." },
        "hasMore": { "type": "boolean" }
      }
    }
  },
  "examples": [
    {
      "command": "source list",
      "sources": [
        { "id": "src_0123456789abcdef", "kind": "file", "locator": "/inbox/sample.md", "title": "Sample", "addedAt": "2026-07-23T10:00:00.000Z", "lastIngestedAt": "2026-07-23T10:05:00.000Z" }
      ],
      "pagination": { "limit": 50, "offset": 0, "total": 1, "hasMore": false }
    }
  ],
  "x-atlas-contract": {
    "command": "source list",
    "phase": 2,
    "privilege": "shared",
    "idempotency": "none",
    "executionClass": "read",
    "summary": "Paginated list of registered sources.",
    "ordering": { "sortKey": "addedAt", "direction": "desc", "tieBreaker": "id", "note": "stable total order (addedAt, id); id is the primary key so ties are fully resolved. Best-effort under concurrency (plan §2.5)." },
    "args": [],
    "flags": [
      { "name": "--limit <n>", "default": 50, "constraint": "1..500" },
      { "name": "--offset <n>", "default": 0, "constraint": ">=0" }
    ],
    "commonFlags": ["--json", "--quiet", "--verbose", "--plain", "--no-color", "--config <path>", "--vault <path>"],
    "sideEffects": [],
    "prohibitedEffects": ["no vault/projection/registry mutation", "no git write"],
    "locks": [{ "scope": "shared", "mode": "shared" }],
    "exitCodes": [0, 2, 4, 5],
    "errorCodes": [
      { "code": "usage", "exit": 5, "when": "unknown flag or out-of-range --limit/--offset" },
      { "code": "config-invalid", "exit": 2, "when": "brain.config.yaml fails schema validation" },
      { "code": "db-unavailable", "exit": 2, "when": "the ledger is absent or not migrated (run `brain db migrate`)" },
      { "code": "internal", "exit": 4, "when": "unexpected internal failure" }
    ],
    "errorEnvelopeRef": "docs/specs/cli-contract/error-envelope.schema.json"
  }
}
