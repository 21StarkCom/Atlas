{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas://cli-contract/git-cleanup.schema.json",
  "title": "brain git cleanup — --json success output",
  "description": "Prune abandoned agent branches/worktrees for terminal or orphaned runs. Convergent (intrinsically idempotent): a repeat run with nothing to prune reports zero and succeeds. Only touches refs/agent/* + their worktrees — never canonical or protected refs.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["command", "prunedBranches", "prunedWorktrees", "details"],
  "properties": {
    "command": { "const": "git cleanup" },
    "prunedBranches": { "type": "integer", "minimum": 0 },
    "prunedWorktrees": { "type": "integer", "minimum": 0 },
    "details": {
      "type": "array",
      "items": {
        "type": "object",
        "unevaluatedProperties": false,
        "required": ["runId", "action"],
        "properties": {
          "runId": { "type": "string", "minLength": 1 },
          "action": { "enum": ["branch-pruned", "worktree-pruned", "branch+worktree-pruned", "skipped-active"] },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "examples": [
    { "command": "git cleanup", "prunedBranches": 0, "prunedWorktrees": 0, "details": [] },
    {
      "command": "git cleanup",
      "prunedBranches": 1,
      "prunedWorktrees": 1,
      "details": [{ "runId": "01J9Z8Q0000000000000000000", "action": "branch+worktree-pruned", "reason": "run terminal (rejected)" }]
    }
  ],
  "x-atlas-contract": {
    "command": "git cleanup",
    "phase": 2,
    "privilege": "shared",
    "idempotency": "intrinsic",
    "executionClass": "mutating",
    "summary": "Prune abandoned agent branches/worktrees.",
    "args": [],
    "flags": [{ "name": "--dry-run", "description": "Report what would be pruned without mutating." }],
    "commonFlags": ["--json", "--quiet", "--verbose", "--plain", "--no-color", "--config <path>", "--vault <path>"],
    "sideEffects": ["removes refs/agent/* branches + worktrees for terminal/orphaned runs"],
    "prohibitedEffects": ["never touches canonical or any protected ref", "never removes a branch/worktree of a non-terminal run"],
    "locks": [{ "scope": "canonical-integration", "mode": "exclusive", "note": "serializes against integration to avoid pruning an in-flight run" }],
    "exitCodes": [0, 2, 4, 5],
    "errorCodes": [
      { "code": "usage", "exit": 5, "when": "unknown flag/argument" },
      { "code": "locked:canonical-integration", "exit": 2, "when": "an integration holds the lock", "retryable": true },
      { "code": "vault-error", "exit": 2, "when": "the vault repo is missing or unreadable" },
      { "code": "internal", "exit": 4, "when": "unexpected internal failure" }
    ],
    "errorEnvelopeRef": "docs/specs/cli-contract/error-envelope.schema.json"
  }
}
