{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas://cli-contract/git-status.schema.json",
  "title": "brain git status — --json success output",
  "description": "Paginated open-run status over the workflow state machine: each non-terminal run with its state, agent branch, base commit, and worktree presence. Read-only.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["command", "runs", "pagination"],
  "properties": {
    "command": { "const": "git status" },
    "runs": {
      "type": "array",
      "description": "Open (non-terminal) runs only — a terminal run is not listed here (use `git cleanup` to prune it).",
      "items": {
        "type": "object",
        "unevaluatedProperties": false,
        "required": ["runId", "state", "branch", "risk", "validation", "baseCommit", "hasWorktree"],
        "properties": {
          "runId": { "type": "string", "minLength": 1, "description": "ULID run id (agent_runs)." },
          "state": {
            "description": "Genuinely OPEN workflow states only (Task 2.9: `git status` lists open runs); terminal states are excluded.",
            "enum": [
              "planned", "patched", "worktree-applied", "agent-committed", "review-pending"
            ]
          },
          "branch": { "type": "string", "minLength": 1, "description": "refs/agent/<runId>." },
          "risk": {
            "description": "Proposed risk tier of the run (Task 2.9 required field).",
            "enum": ["tier-1", "tier-2", "tier-3"]
          },
          "validation": {
            "description": "Validation status of the run's current patch (Task 2.9 required field). `pending` before validation runs; `passed`/`failed` after.",
            "enum": ["pending", "passed", "failed"]
          },
          "baseCommit": { "type": "string", "minLength": 1, "description": "40-char hex commit the agent branch is based on (Task 2.9 required field)." },
          "hasWorktree": { "type": "boolean" },
          "updatedAt": { "type": "string" }
        }
      }
    },
    "pagination": {
      "type": "object",
      "unevaluatedProperties": false,
      "required": ["limit", "offset", "total", "hasMore"],
      "properties": {
        "limit": { "type": "integer", "minimum": 1, "maximum": 500 },
        "offset": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0, "description": "Live (non-snapshot) total open-run count; best-effort under concurrency." },
        "hasMore": { "type": "boolean" }
      }
    }
  },
  "examples": [
    {
      "command": "git status",
      "runs": [
        { "runId": "01J9Z8Q0000000000000000000", "state": "review-pending", "branch": "refs/agent/01J9Z8Q0000000000000000000", "risk": "tier-3", "validation": "passed", "baseCommit": "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0", "hasWorktree": true, "updatedAt": "2026-07-13T10:00:00.000Z" }
      ],
      "pagination": { "limit": 50, "offset": 0, "total": 1, "hasMore": false }
    }
  ],
  "x-atlas-contract": {
    "command": "git status",
    "phase": 2,
    "privilege": "shared",
    "idempotency": "none",
    "executionClass": "read",
    "summary": "Paginated open-run status.",
    "ordering": { "sortKey": "updatedAt", "direction": "desc", "tieBreaker": "runId", "note": "stable total order (updatedAt, runId); runId (ULID) is unique so ties are fully resolved." },
    "args": [],
    "flags": [
      { "name": "--limit <n>", "default": 50, "constraint": "1..500" },
      { "name": "--offset <n>", "default": 0, "constraint": ">=0" }
    ],
    "commonFlags": ["--json", "--quiet", "--verbose", "--plain", "--no-color", "--config <path>", "--vault <path>"],
    "sideEffects": [],
    "prohibitedEffects": ["no branch/worktree/ref mutation", "no ledger or audit-ref write"],
    "locks": [{ "scope": "shared", "mode": "shared" }],
    "exitCodes": [0, 2, 4, 5],
    "errorCodes": [
      { "code": "usage", "exit": 5, "when": "unknown flag or out-of-range pagination" },
      { "code": "vault-error", "exit": 2, "when": "the vault repo is missing or unreadable" },
      { "code": "internal", "exit": 4, "when": "unexpected internal failure" }
    ],
    "errorEnvelopeRef": "docs/specs/cli-contract/error-envelope.schema.json"
  }
}
