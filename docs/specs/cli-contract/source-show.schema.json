{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas://cli-contract/source-show.schema.json",
  "title": "brain source show — --json success output",
  "description": "Show one registered source from the v2 operational `source` registry (0015_source_registry), resolved by id then (fallback) by its UNIQUE locator. Tier-0 read; no mutation.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["command", "source"],
  "properties": {
    "command": { "const": "source show" },
    "source": {
      "type": "object",
      "unevaluatedProperties": false,
      "required": ["id", "kind", "locator", "addedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["file", "url"] },
        "locator": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "addedAt": { "type": "string", "description": "RFC-3339 time the source was added." },
        "lastIngestedAt": { "type": "string", "description": "RFC-3339 time `ingest` last folded this source (present only once ingested)." }
      }
    }
  },
  "examples": [
    {
      "command": "source show",
      "source": {
        "id": "src_0123456789abcdef",
        "kind": "url",
        "locator": "https://example.com/doc",
        "title": "Example Doc",
        "addedAt": "2026-07-23T10:00:00.000Z"
      }
    }
  ],
  "x-atlas-contract": {
    "command": "source show",
    "phase": 2,
    "privilege": "shared",
    "idempotency": "none",
    "executionClass": "read",
    "summary": "Show one registered source (resolved by id or locator).",
    "args": [{ "name": "<source>", "required": true, "description": "A source id or locator." }],
    "flags": [],
    "commonFlags": ["--json", "--quiet", "--verbose", "--plain", "--no-color", "--config <path>", "--vault <path>"],
    "sideEffects": [],
    "prohibitedEffects": ["no vault/projection/registry mutation", "no git write"],
    "locks": [{ "scope": "shared", "mode": "shared" }],
    "exitCodes": [0, 1, 2, 4, 5],
    "errorCodes": [
      { "code": "usage", "exit": 5, "when": "missing <source> argument or unknown flag" },
      { "code": "source-not-found", "exit": 1, "when": "no source resolves for the handle (by id or locator)" },
      { "code": "config-invalid", "exit": 2, "when": "brain.config.yaml fails schema validation" },
      { "code": "db-unavailable", "exit": 2, "when": "the ledger is absent or not migrated (run `brain db migrate`)" },
      { "code": "internal", "exit": 4, "when": "unexpected internal failure" }
    ],
    "errorEnvelopeRef": "docs/specs/cli-contract/error-envelope.schema.json"
  }
}
