<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Egress broker daemon (D13/D18): sole provider-credential holder + sole
     outbound-network process. Installed by provisioning/macos/services.sh. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.atlas.egress</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/lib/atlas/bin/egress-launcher.sh</string>
  </array>
  <key>UserName</key><string>atlas-egress</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ThrottleInterval</key><integer>5</integer>
  <key>StandardOutPath</key><string>/usr/local/var/log/atlas/egress.log</string>
  <key>StandardErrorPath</key><string>/usr/local/var/log/atlas/egress.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
