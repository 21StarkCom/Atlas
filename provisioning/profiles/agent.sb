;; Atlas agent Seatbelt profile (macOS) — Task 1.0 / #16, D17.
;; Applied to parser/agent processes: deny outbound network entirely (only
;; atlas-egress may reach the internet), deny keychain, restrict FS to the vault +
;; a worker-private temp. Loaded via `sandbox-exec -f agent.sb <cmd>` OR compiled
;; into the sandbox launcher (Task 2.3). This profile is the network-denial backstop
;; that does NOT depend on the agent choosing a launcher when paired with the per-UID
;; pf anchor (agent-pf.conf).
(version 1)
(deny default)

;; --- no network at all (the load-bearing denial) ---
(deny network*)

;; --- process basics ---
(allow process-fork)
(allow process-exec (with no-sandbox))            ;; child re-enters via its own profile
(allow signal (target self))
(allow sysctl-read)
(allow mach-lookup)

;; --- read-only system libs/frameworks ---
(allow file-read*
  (subpath "/usr/lib")
  (subpath "/usr/bin")
  (subpath "/System/Library")
  (subpath "/Library/Frameworks"))

;; --- vault + worker temp (parameterized; the launcher substitutes real paths) ---
;; (import these via (param "VAULT_DIR") / (param "WORK_TMP") when invoked with -D)
(allow file-read* (subpath (param "VAULT_DIR")))
(allow file-read* file-write* (subpath (param "WORK_TMP")))

;; --- explicit denials for defense-in-depth ---
(deny file-read* (subpath "/Users"))              ;; no home/keychain snooping…
(allow file-read* (subpath (param "VAULT_DIR")))  ;; …except the vault, re-allowed above
(deny file-read* (literal "/Library/Keychains"))
(deny file-read* (subpath (param "HOME_KEYCHAIN")))
